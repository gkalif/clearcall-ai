# ── Database ─────────────────────────────────
DATABASE_URL=sqlite:///./clearcall.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/clearcall

# ── Auth ─────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production-please

# ── AI APIs ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # Required for transcript cleaning + summarization
OPENAI_API_KEY=sk-...          # Required for TTS (optional if TTS_BACKEND=mock)

# ── Pipeline config ───────────────────────────
# STT_BACKEND options:
#   whisper_local  → free, runs on your machine (pip install openai-whisper)
#   whisper_api    → hosted OpenAI Whisper, ~$0.006/min (needs OPENAI_API_KEY)
#   mock           → no STT, returns placeholder text (for testing UI only)
STT_BACKEND=whisper_local

# TTS_BACKEND options:
#   openai  → OpenAI tts-1-hd, voice=nova, ~$0.015/1000 chars (needs OPENAI_API_KEY)
#   mock    → silent WAV placeholder (for testing without API keys)
TTS_BACKEND=openai

# Whisper model size (only for whisper_local):
#   tiny=39M params, base=74M, small=244M, medium=769M, large=1.5B
#   base is the right default for MVP — fast enough, accurate enough
WHISPER_MODEL=base

# ── Storage ───────────────────────────────────
# Local filesystem for MVP. Switch to S3 for production.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=clearcall-audio
# AWS_REGION=us-east-1
